# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Force specific text files to always use LF line endings
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.policy text eol=lf
*.csv text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env* text eol=lf
